<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tiprasa Traditional Dress | Rignai Risa Store</title>
<meta name="description" content="Buy authentic Tiprasa traditional dresses including Rignai, Risa, Takborok, Duti and tribal designs from Tripura.">

<style>
body{font-family:Arial;margin:0;background:#f4f4f4}
header{background:#7a0c2e;color:white;padding:16px;text-align:center}
nav{background:#111;color:white;padding:10px;text-align:center}
nav button{margin:5px;padding:8px 12px;border:none;border-radius:5px;cursor:pointer}
.container{padding:20px}
.search{width:100%;padding:10px;margin-bottom:20px;border-radius:6px;border:1px solid #ccc}
.products{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.card{background:white;border-radius:10px;padding:15px;box-shadow:0 2px 6px rgba(0,0,0,0.1)}
.card img{width:100%;height:200px;object-fit:cover;border-radius:8px}
.price{font-weight:bold}
button{padding:8px 10px;border:none;border-radius:6px;cursor:pointer}
.order{background:#25D366;color:white;width:100%;margin-top:10px}
.pay{background:#4CAF50;color:white;width:100%;margin-top:6px}
.delete{background:#d11a2a;color:white;margin-top:6px}
.admin{margin-top:40px;background:white;padding:20px;border-radius:10px}
input,select{padding:8px;margin:5px;width:100%}
.login{background:white;padding:20px;border-radius:10px;max-width:400px;margin:auto;margin-top:40px}
.hidden{display:none}
</style>
</head>

<body>

<header>
<h1>Tiprasa Traditional Dress Store</h1>
<p>Authentic Tripura Tribal Clothing</p>
</header>

<nav>
<button onclick="filterCategory('all')">All</button>
<button onclick="filterCategory('Rignai')">Rignai</button>
<button onclick="filterCategory('Risa')">Risa</button>
<button onclick="filterCategory('Takborok')">Takborok</button>
<button onclick="filterCategory('Blouse')">Blouse</button>
<button onclick="filterCategory('Duti')">Duti</button>
</nav>

<div class="container">

<input id="search" class="search" placeholder="Search products..." onkeyup="searchProduct()">

<div class="products" id="productList"></div>

<div class="login" id="loginBox">
<h2>Admin Login</h2>
<input id="adminUser" placeholder="Username">
<input id="adminPass" type="password" placeholder="Password">
<button onclick="login()">Login</button>
</div>

<div class="admin hidden" id="adminPanel">
<h2>Admin Dashboard</h2>

<h3>Add Product (Product Wise Price)</h3>
<input id="name" placeholder="Product Name (Example: Jamatia Rignai)">
<input id="price" type="number" placeholder="Product Price ₹ (Example: 1500)">
<input id="image" placeholder="Product Image URL">
<select id="category">
<option>Rignai</option>
<option>Risa</option>
<option>Takborok</option>
<option>Blouse</option>
<option>Duti</option>
</select>
<button onclick="addProduct()">Add Product With Price</button>

<h3>Orders</h3>
<p>Orders will come to your WhatsApp.</p>

<h3>UPI Payment</h3>
<p>UPI ID: <b id="upiDisplay">yourupi@upi</b></p>

</div>

</div>

<script>

let products = JSON.parse(localStorage.getItem('products')) || [
{name:"Tripura Rignai",price:1500,image:"https://via.placeholder.com/300",category:"Rignai"},
{name:"Jamatia Rignai",price:1700,image:"https://via.placeholder.com/300",category:"Rignai"},
{name:"Tiprasa Risa",price:600,image:"https://vajiramandravi.com/current-affairs/wp-content/uploads/2025/04/risa_textile.webp",category:"Risa"},
{name:"Takborok Blouse",price:900,image:"https://via.placeholder.com/300",category:"Blouse"},
{name:"Chandrahar",price:900,image:"https://via.placeholder.com/300",category:"Blouse"}
]

function save(){
localStorage.setItem("products",JSON.stringify(products))
}

function display(list = products){
let html = ""

list.forEach((p,index)=>{
html += `
<div class="card">
<img src="${p.image}" alt="${p.name}">
<h3>${p.name}</h3>
<p class="price">₹${p.price}</p>
<p>${p.category}</p>

<button class="order" onclick="orderProduct(${index})">Order WhatsApp</button>
<button class="pay" onclick="upiPay(${p.price})">Pay UPI</button>
<button class="delete" onclick="deleteProduct(${index})">Delete</button>

</div>
`
})

document.getElementById("productList").innerHTML = html
}

function addProduct(){

let name = document.getElementById("name").value.trim()
let price = document.getElementById("price").value
let image = document.getElementById("image").value.trim()
let category = document.getElementById("category").value

if(name === "" || price === "" || image === ""){
alert("Please fill all product fields")
return
}

products.push({
name:name,
price:Number(price),
image:image,
category:category
})

save()

document.getElementById("name").value=""
document.getElementById("price").value=""
document.getElementById("image").value=""

display()
}

function deleteProduct(index){
products.splice(index,1)
save()
display()
}

function searchProduct(){
let value = document.getElementById("search").value.toLowerCase()

let filtered = products.filter(p =>
p.name.toLowerCase().includes(value)
)

display(filtered)
}

function filterCategory(cat){

if(cat === "all"){
display()
return
}

let filtered = products.filter(p => p.category === cat)

display(filtered)
}

function orderProduct(index){

let product = products[index]

let phone = "91XXXXXXXXXX"

let message = `Hello, I want to order:\nProduct: ${product.name}\nPrice: ₹${product.price}`

let url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`

window.open(url,"_blank")
}

function upiPay(price){

let upi = "yourupi@upi"

let paymentLink = `upi://pay?pa=${upi}&pn=TiprasaDress&am=${price}&cu=INR`

window.open(paymentLink)
}

function login(){

let u = document.getElementById("adminUser").value
let p = document.getElementById("adminPass").value

if(u === "admin" && p === "1234"){

document.getElementById("loginBox").classList.add("hidden")

document.getElementById("adminPanel").classList.remove("hidden")

}else{
alert("Wrong login details")
}
}

// Start website

display()

</script>

</body>
</html>
